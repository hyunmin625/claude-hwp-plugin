{
  "name": "claude-hwp-plugin-mcp",
  "version": "0.1.0",
  "description": "MCP Server for HWP/HWPX Korean document control via Claude Code",
  "type": "module",
  "bin": {
    "claude-hwp-mcp": "./dist/index.js"
  },
